{
  "name": "zenkai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev worker/index.js",
    "worker:deploy": "wrangler deploy",
    "worker:db:migrate": "node scripts/run-d1-migrations.mjs",
    "worker:db:migrate:remote": "node scripts/run-d1-migrations.mjs --remote",
    "worker:db:init": "npm run worker:db:migrate",
    "worker:db:init:remote": "npm run worker:db:migrate:remote",
    "worker:db:snapshot": "wrangler d1 execute zenkai --file=worker/schema.sql",
    "worker:db:snapshot:remote": "wrangler d1 execute zenkai --remote --file=worker/schema.sql",
    "equipment:validate": "node scripts/validate-equipment-balance.mjs"
  },
  "devDependencies": {
    "vite": "^7.3.1",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-ethers": "^1.8.19",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "g": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "playwright": "^1.59.1"
  }
}
